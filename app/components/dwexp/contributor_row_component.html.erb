<tr>
  <th scope="row" class="text-nowrap">
    <%= render_name %>
  </th>
  <td class="text-nowrap">
    <%= render_collaborators_link %>
  </td>
  <td>
    <% Array(@contributor['affiliation']).each do |affiliation| %>
      <div class="d-flex justify-content-between align-items-start mb-1">
        <div class="d-flex flex-column">
          <span><%= affiliation['name'] %><%= render_ror_link(affiliation) %></span>
          <% departments(affiliation).each do |department| %>
            <span class="text-muted d-block ms-2">
              <i class="bi bi-arrow-return-right"></i>
              <%= department %>
            </span>
          <% end %>
        </div>
        <%= render_affiliation_country(affiliation) %>
      </div>
    <% end %>
  </td>
</tr>
