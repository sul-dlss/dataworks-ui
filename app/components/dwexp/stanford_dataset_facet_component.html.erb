<div class="d-flex justify-content-center align-items-center mt-2 mb-4">
  <a class="btn btn-outline-primary btn-stanford-cardinal text-decoration-none py-2 px-3 <%= 'active' if presenter.selected? %>" href="<%= presenter.href %>">
    <% if presenter.selected? %>
      <input type="checkbox" class="me-2" style="pointer-events: none;" checked>
    <% else %>
      <input type="checkbox" class="me-2" style="pointer-events: none;">
    <% end %>
    <%= @facet_field.label %>
  </a>
</div>
