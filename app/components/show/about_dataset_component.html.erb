<div class="border rounded-2 align-items-center gap-3 p-3 mt-3">
  <div class="d-flex flex-wrap justify-content-between align-items-start column-gap-3 row-gap-1 mb-3">
    <div>
      <h2 class="m-0 d-flex flex-wrap align-items-center gap-2">
        <%= t('.heading') %>
        <%= render Badges::AccessComponent.new(document: document) %>
      </h2>
      <% if document.url.present? %>
        <span class="available-at"><%= t('.available_at') %> <%= document.url_host %></span>
      <% end %>
    </div>
    <div class="d-flex flex-wrap gap-3">
      <% if document.publication_year.present? %>
        <span><%= t('.published', year: document.publication_year) %></span>
      <% end %>
      <% if document.version.present? %>
        <span><%= t('.version', version: document.version) %></span>
      <% end %>
    </div>
  </div>
  <div class="bg-light rounded-2 d-flex justify-content-between align-items-center gap-3 p-3">
    <div class="d-flex flex-wrap gap-3 flex-grow-1">
      <% if document.sizes.present? %>
        <span><%= t('.size_html', size: document.sizes.join(', ')) %></span>
      <% end %>
      <% if document.formats.present? %>
        <span><%= t('.formats_html', formats: document.formats.join(', ')) %></span>
      <% end %>
      <% if document.doi.present? %>
        <span><%= t('.doi_html', doi: document.doi) %></span>
      <% end %>
    </div>
    <% if document.url.present? %>
      <%= link_to document.url, class: 'btn btn-primary d-inline-flex align-items-center gap-1 w-auto flex-shrink-0 align-self-end', target: '_blank', rel: 'noopener' do %>
        <%= t('.button') %>
        <%= render Icons::ArrowUpRightComponent.new(aria_hidden: true) %>
      <% end %>
    <% end %>
  </div>
</div>
