<div id="contributors">
  <h2><%= t('.heading') %></h2>
  <table class="table table-sm m-2">
    <thead class="visually-hidden">
      <tr>
        <th scope="col">Name</th>
        <th scope="col">Collaborators</th>
        <th scope="col">Affiliations</th>
      </tr>
    </thead>
    <tbody>
      <% contributors.each do |contributor| %>
        <%= render Show::ContributorRowComponent.new(facet_field: FACET_FIELD, contributor: contributor) %>
      <% end %>
    </tbody>
  </table>
</div>
