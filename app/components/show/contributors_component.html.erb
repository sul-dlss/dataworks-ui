<div id="contributors">
  <h2><%= t('.heading') %></h2>
  <div data-controller="expand-items" data-expand-items-max-rows-value="<%= VISIBLE_COUNT %>">
    <table class="table">
      <thead class="visually-hidden">
        <tr>
          <th scope="col"><%= t('.contributor') %></th>
          <th scope="col"><%= t('.affiliation') %></th>
        </tr>
      </thead>
      <tbody>
        <% contributors.each do |contributor| %>
          <tr data-expand-items-target="item">
            <td class="py-1"><%= render_name(contributor) %><%= render_orcid_link(contributor) %><%= render_profile_link(contributor) %></td>
            <td class="py-1 small"><%= render_affiliations(contributor) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <button type="button"
            data-expand-items-target="toggle"
            data-action="expand-items#toggle"
            class="btn btn-link p-0 mt-2 small text-decoration-none"
            hidden>
      <span data-expand-items-target="moreControl" class="expand-text__control align-items-center gap-1">
        <%= render Icons::ArrowDownCircleComponent.new(aria_hidden: true) %><%= t('.show_more') %>
      </span>
      <span data-expand-items-target="lessControl" class="expand-text__control align-items-center gap-1" hidden>
        <%= render Icons::ArrowUpCircleComponent.new(aria_hidden: true) %><%= t('.show_less') %>
      </span>
    </button>
  </div>
</div>
