<!DOCTYPE html>
<%= content_tag :html, class: 'no-js', **html_tag_attributes do %>
  <head>
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="turbo-prefetch" content="false">

    <title><%= render_page_title %></title>
    <script>
      document.querySelector('html').classList.remove('no-js');
    </script>
    <%= opensearch_description_tag application_name, opensearch_catalog_url(format: 'xml') %>
    <%= favicon_link_tag %>
    <%= render 'shared/head' %>

    <% if defined? Importmap %>
      <%= javascript_importmap_tags %>
    <% else %>
      <%= javascript_include_tag "application", "data-turbo-track": "reload", defer: true %>
    <% end %>

    <%= csrf_meta_tags %>
    <%= content_for(:head) %>
  </head>
  <body class="<%= render_body_class %> d-flex flex-column min-vh-100" data-controller="analytics">
    <%= render blacklight_config.skip_link_component.new do %>
      <%= content_for(:skip_links) %>
    <% end %>

    <%= render blacklight_config.header_component.new(blacklight_config: blacklight_config) %>

    <main id="main-container" class="<%= container_classes %> flex-grow-1" aria-label="<%= t('blacklight.main.aria.main_container') %>">
      <%= content_for(:container_header) %>

      <%= render 'shared/flash_msg', layout: 'shared/flash_messages' if flash.any? %>

      <div class="row">
        <%= content_for?(:content) ? yield(:content) : yield %>
      </div>
    </main>

    <div id="toast-area" data-turbo-permanent class="toast-container position-fixed bottom-0 end-0 p-3" data-controller="toast-container" data-action="show-toast@window->toast-container#showToast">
      <template id="toast-template">
        <%= render ToastComponent.new %>
      </template>
    </div>

    <%= render partial: 'shared/footer' %>
    <%= render partial: 'shared/modal' %>
  </body>
<% end %>
